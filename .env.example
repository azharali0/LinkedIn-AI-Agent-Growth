# ╔══════════════════════════════════════════════════════════════╗
# ║        LINKEDIN AGENT — 100% FREE STACK CONFIG             ║
# ╚══════════════════════════════════════════════════════════════╝

# ── AI: Google Gemini 1.5 Flash (FREE — 1500 requests/day) ────
# Get it: https://aistudio.google.com/app/apikey  (1 click, no card)
GEMINI_API_KEY=AIza-your-gemini-key-here

# ── LinkedIn API (FREE to use — just needs setup) ─────────────
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_ACCESS_TOKEN=your-linkedin-long-lived-access-token
LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_ID

# ── Images: Pexels (FREE — 200 req/hour) ──────────────────────
# Get it: https://www.pexels.com/api/  (instant, no card)
PEXELS_API_KEY=your-pexels-api-key

# ── Email: Gmail SMTP (FREE) ───────────────────────────────────
# How to get App Password (NOT your real password):
# myaccount.google.com → Security → 2FA ON → App Passwords
GMAIL_USER=prog.azharexp@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPROVAL_EMAIL=prog.azharexp@gmail.com

# ── Server (for Koyeb/Render free hosting) ────────────────────
PORT=3000
BASE_URL=https://your-app.koyeb.app
SECRET_TOKEN=change-this-to-any-random-string

# ── Schedule ──────────────────────────────────────────────────
# Used by GitHub Actions cron — "0 4 * * *" = 9 AM PKT (UTC+5)
# This env var is only used if running server mode
POST_CRON=0 4 * * *
TIMEZONE=Asia/Karachi
